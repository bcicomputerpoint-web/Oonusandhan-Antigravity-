{
  "name": "onusandhan-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node start.js",
    "dev": "npm run dev --workspaces --if-present",
    "build": "node -e \"if (process.platform !== 'win32') require('child_process').execSync('chmod -R 755 .')\" && npm run build --workspace=@onusandhan/types && npm run db:generate --workspace=@onusandhan/db && npm run build --workspace=@onusandhan/db && npm run build --workspace=@onusandhan/ui && npm run build --workspace=@onusandhan/api && npm run build --workspace=@onusandhan/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "db:generate": "npm run db:generate --workspace=@onusandhan/db",
    "db:migrate": "npm run db:migrate --workspace=@onusandhan/db"
  },
  "dependencies": {
    "typescript": "^5.3.3",
    "prisma": "^5.11.0",
    "ts-node": "^10.9.2",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/node": "^20.11.24",
    "@types/bcryptjs": "^2.4.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5"
  }
}
